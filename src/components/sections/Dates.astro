---
import { getConcerts } from '../../lib/sanity'

const concerts = await getConcerts()

const today = new Date().toISOString().split('T')[0]
const upcoming = concerts.filter(c => c.date >= today)
const past     = concerts.filter(c => c.date <  today)

function formatDate(iso: string): string {
  const [year, month, day] = iso.split('-')
  return `${day}/${month}/${year}`
}
---

<div class="section-wrap">
  <section id="dates-all" class="dates-all-section">
    <div class="dates-all-list">
      <!-- SANITY-DEBUG: {concerts.length} Konzerte geladen -->

      <div class="dates-all-item dates-all-label">
        <span class="dates-all-date"></span>
        <span class="dates-all-detail">UPCOMING</span>
        <span class="dates-all-location"></span>
      </div>

      {upcoming.map(c => (
        <div
          class="dates-all-item"
          data-bg={c.imageUrl ?? undefined}
          data-credit={c.imageCredit ?? undefined}
        >
          <span class="dates-all-date">{formatDate(c.date)}</span>
          <span class="dates-all-title">{c.venue}</span>
          {c.detail && <span class="dates-all-detail">{c.detail}</span>}
          <span class="dates-all-location">{c.city}</span>
        </div>
      ))}

      <div class="dates-all-item dates-all-label" id="dates-past-label">
        <span class="dates-all-date"></span>
        <span class="dates-all-detail">PAST</span>
        <span class="dates-all-location"></span>
      </div>

      {past.map(c => (
        <div
          class="dates-all-item"
          data-bg={c.imageUrl ?? undefined}
          data-credit={c.imageCredit ?? undefined}
        >
          <span class="dates-all-date">{formatDate(c.date)}</span>
          <span class="dates-all-title">{c.venue}</span>
          {c.detail && <span class="dates-all-detail">{c.detail}</span>}
          <span class="dates-all-location">{c.city}</span>
        </div>
      ))}

    </div>
  </section>
</div>
