    <section id="work-2" class="section-fullscreen">
      <video class="bg-media" id="video-2"
        data-hls="https://vz-64816067-a45.b-cdn.net/7b83cc48-31c9-4cb9-8315-0733407a57ba/playlist.m3u8"
